# Copy this file to .env.local and fill in your own values.
# .env.local is gitignored and never committed.

# Google AI Studio (Gemini) API key - create a free key at
# https://aistudio.google.com/apikey
# Used server-side only (app/api/tutor-token/route.ts) to mint ephemeral tokens for the Tutor tab's Gemini live session. Never sent to the browser.
GEMINI_API_KEY=

# Hugging Face token for Tutor tab image generation (FLUX.1-schnell).
# Create at https://huggingface.co/settings/tokens - enable "Inference Providers".
# Also accept the model terms at https://huggingface.co/black-forest-labs/FLUX.1-schnell
# Used server-side only (app/api/image-generate/route.ts). Set the same value on Vercel.
HF_TOKEN=

# ElevenLabs API key for the Spelling tab's "Make a song" feature (ElevenLabs
# Music). Requires a paid ElevenLabs plan with Music access. Create a key at
# https://elevenlabs.io/app/settings/api-keys — used server-side only
# (app/api/spelling-song/route.ts), never sent to the browser. Set the same value
# on Vercel.
ELEVENLABS_API_KEY=

# Optional: ElevenLabs Music model. Defaults to music_v2 (best sung vocals) when
# unset; set music_v1 to fall back.
ELEVENLABS_MUSIC_MODEL=

# Optional: default ElevenLabs narrator voice for the board's "Story time"
# feature (app/api/story). Falls back to a built-in storyteller voice when unset;
# the modal normally lets the teacher pick from the account's voices.
ELEVENLABS_VOICE_ID=

# Optional: ElevenLabs text-to-speech model for Story time and
# `npm run gen:pet-voices`. Defaults to eleven_v3. Per-species pet voices are
# configured in lib/pet-voice-lines.json (child + teen mix).
ELEVENLABS_TTS_MODEL=

# Pixabay API key for the Tutor "Web image" provider (real illustrations).
# Free key (no card): sign in at https://pixabay.com then open
# https://pixabay.com/api/docs/ - your key is shown in the "key" parameter row.
# Used server-side only (app/api/image-search/route.ts). Set the same value on Vercel.
# Without it, the "Web image" option silently falls back to Pollinations.
PIXABAY_API_KEY=

# Google Sheets service account, for the Resources tab's live lesson-plan
# sync (app/api/lesson-plan-sheet/route.ts). Create a GCP project, enable the
# Google Sheets API, create a service account, and generate a JSON key -
# https://console.cloud.google.com. Share each teacher's lesson-plan sheet
# with GOOGLE_SHEETS_CLIENT_EMAIL (as Editor) for the sync to work. Used
# server-side only, never sent to the browser. Set the same values on Vercel.
GOOGLE_SHEETS_CLIENT_EMAIL=
# The service account's private_key from the downloaded JSON key. Paste it as
# a single line with literal "\n" in place of real newlines (most
# JSON-to-.env tools do this automatically) - the code un-escapes it before use.
GOOGLE_SHEETS_PRIVATE_KEY=
