# Copy this file to .env.local and fill in your own values.
# .env.local is gitignored and never committed.

# Google AI Studio (Gemini) API key - create a free key at
# https://aistudio.google.com/apikey
# Used server-side only (app/api/tutor-token/route.ts) to mint ephemeral tokens for the Tutor tab's Gemini live session. Never sent to the browser.
GEMINI_API_KEY=

# Hugging Face token for Tutor tab image generation (FLUX.1-schnell).
# Create at https://huggingface.co/settings/tokens - enable "Inference Providers".
# Also accept the model terms at https://huggingface.co/black-forest-labs/FLUX.1-schnell
# Used server-side only (app/api/image-generate/route.ts). Set the same value on Vercel.
HF_TOKEN=
